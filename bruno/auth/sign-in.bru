meta {
  name: Sign In
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/v1/auth/sign-in
  body: json
  auth: none
}

body:json {
  {
    "email": "user@example.com",
    "password": "password123"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setEnvVar("accessToken", res.body.accessToken);
    bru.setEnvVar("refreshToken", res.body.refreshToken);
  }
}
