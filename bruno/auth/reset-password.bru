meta {
  name: Reset Password
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/v1/auth/reset-password/:token
  body: json
  auth: none
}

params:path {
  token: your-reset-token-here
}

body:json {
  {
    "email": "user@example.com",
    "password": "newpassword123",
    "passwordConfirmation": "newpassword123"
  }
}
