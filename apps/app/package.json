{
  "name": "@echoes/app",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint . --fix",
    "format": "prettier --write .",
    "check": "tsc --noEmit",
    "style": "yarn format && yarn lint && yarn check",
    "test": "jest --ci --coverage",
    "test:watch": "jest --watch --coverage=false --changedSince=origin/main",
    "test:debug": "jest -o --watch --coverage=false",
    "test:ci": "jest --ci --coverage",
    "test:update-snapshots": "jest -u --coverage=false",
    "eas:build:dev": "eas build --profile development",
    "eas:build:preview": "eas build --profile preview",
    "eas:build:prod": "eas build --profile production",
    "eas:submit": "eas submit --profile production",
    "eas:update": "eas update",
    "build-submit:prod:ios": "eas build --platform ios --auto-submit",
    "build-submit:prod:android": "eas build --platform android --auto-submit",
    "eas:doctor": "npx expo-doctor",
    "nuke": "rm -rf ./node_modules ./ios ./android .expo"
  },
  "dependencies": {
