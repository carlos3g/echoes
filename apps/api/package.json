{
  "name": "@echoes/api",
  "version": "0.0.1",
  "description": "",
  "license": "MIT",
  "author": "carlos3g",
  "scripts": {
    "build": "nest build",
    "check": "tsc --noEmit",
    "db:fresh": "yarn db:generate && yarn db:migrate && yarn db:seed",
    "db:generate": "prisma generate",
    "db:migrate": "prisma db push",
    "db:migrate:test": "dotenv -e .env.testing -- prisma db push --accept-data-loss",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "dev": "yarn start:dev",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "start": "nest start",
    "start:debug": "nest start --debug --watch",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "start:repl": "nest start --watch --entryFile repl",
    "style": "yarn format && yarn lint && yarn check",
    "test": "jest",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --runInBand --config ./test/jest-e2e.json",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.952.0",
    "@nestjs-modules/mailer": "^2.0.2",
    "@nestjs/common": "^11.1.9",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.9",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/platform-express": "^11.1.9",
    "@nestjs/schedule": "^6.1.0",
    "@nestjs/swagger": "^11.2.3",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.19.1",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "helmet": "^8.1.0",
    "image-size": "^2.0.2",
    "jdenticon": "^3.3.0",
    "lodash": "^4.17.21",
    "luxon": "^3.7.2",
    "mjml": "^4.18.0",
    "nestjs-cls": "^6.1.0",
    "nodemailer": "^7.0.11",
    "prisma": "^6.19.1",
    "pug": "^3.0.3",
    "qs": "^6.14.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.34.5",
    "type-fest": "^5.3.1",
    "uuid": "^13.0.0",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@faker-js/faker": "^10.1.0",
    "@nestjs/cli": "^11.0.14",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.9",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.21",
    "@types/luxon": "^3.7.1",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.0.2",
    "@types/nodemailer": "^7.0.4",
    "@types/qs": "^6.14.0",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^11.0.0",
    "@types/zxcvbn": "^4.4.5",
    "aws-sdk-client-mock": "^4.1.0",
    "aws-sdk-client-mock-jest": "^4.1.0",
    "dotenv": "^17.2.3",
    "dotenv-cli": "^11.0.0",
    "dotenv-expand": "^12.0.3",
    "eslint": "^9",
    "eslint-config-prettier": "^10",
    "eslint-plugin-jest": "^28",
    "eslint-plugin-prettier": "^5",
    "globals": "^16",
    "jest": "^30.2.0",
    "jest-mock": "^30.2.0",
    "prettier": "^3.7.4",
    "prettier-plugin-packagejson": "^2.5.20",
    "prisma-dbml-generator": "^0.12.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8",
    "webpack": "^5.103.0"
  },
  "overrides": {
    "@nestjs-modules/mailer": {
      "@nestjs/common": "$@nestjs/common"
    }
  },
  "prisma": {
    "seed": "ts-node --transpile-only -P ./tsconfig.json prisma/seed.ts"
  }
}
