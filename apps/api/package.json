{
  "name": "@echoes/api",
  "version": "0.0.1",
  "description": "",
  "license": "MIT",
  "author": "carlos3g",
  "scripts": {
    "build": "nest build",
    "check": "tsc --noEmit",
    "db:fresh": "yarn db:generate && yarn db:migrate && yarn db:seed",
    "db:generate": "prisma generate",
    "db:migrate": "prisma db push",
    "db:search-indexes": "node -e \"require('dotenv-expand').expand(require('dotenv').config()); const {execSync}=require('child_process'); const u=new URL(process.env.DB_URL); u.search=''; execSync('psql \\\"'+u.toString()+'\\\" -f prisma/migrations/add-search-indexes.sql', {stdio:'inherit'})\"",
    "db:migrate:test": "dotenv -e .env.testing -- prisma db push --accept-data-loss",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "dev": "yarn start:dev",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "start": "nest start",
    "start:debug": "nest start --debug --watch",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "start:repl": "nest start --watch --entryFile repl",
    "style": "yarn format && yarn lint && yarn check",
    "test": "jest",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --runInBand --config ./test/jest-e2e.json",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@nestjs-modules/mailer": "^2.3.4",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "7",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "~0.14.0",
    "helmet": "^8.1.0",
    "image-size": "^2.0.2",
    "jdenticon": "^3.3.0",
    "lodash": "^4.17.23",
    "luxon": "^3.7.2",
    "mjml": "^4.18.0",
    "nestjs-cls": "^6.2.0",
    "nodemailer": "^8.0.4",
    "prisma": "7",
    "pug": "^3.0.4",
    "qs": "^6.15.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.34.5",
    "type-fest": "^5.5.0",
    "uuid": "^13.0.0",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@faker-js/faker": "^10.4.0",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.17",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/luxon": "^3.7.1",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/qs": "^6.15.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^11.0.0",
    "@types/zxcvbn": "^4.4.5",
    "aws-sdk-client-mock": "^4.1.0",
    "aws-sdk-client-mock-jest": "^4.1.0",
    "dotenv": "^17.3.1",
    "dotenv-cli": "^11.0.0",
    "dotenv-expand": "^12.0.3",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.1",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "jest-mock": "^30.3.0",
    "prettier": "^3.8.1",
    "prettier-plugin-packagejson": "^3.0.2",
    "prisma-dbml-generator": "^0.12.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5",
    "typescript-eslint": "^8.57.2",
    "webpack": "^5.105.4"
  },
  "overrides": {
    "@nestjs-modules/mailer": {
      "@nestjs/common": "$@nestjs/common"
    }
  }
}
