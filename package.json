{
  "name": "echoes",
  "version": "0.0.1",
  "private": true,
  "description": "",
  "license": "MIT",
  "author": "carlos3g",
  "scripts": {
    "prepare": "husky",
    "style": "lerna run style",
    "dev": "lerna run dev",
    "dev:webapp": "lerna run dev --scope @echoes/webapp",
    "dev:api": "lerna run dev --scope @echoes/api",
    "dev:app": "lerna run start --scope @echoes/app",
    "clean": "lerna clean && rm -rf node_modules",
    "db": "lerna run db:generate && lerna run db:migrate && lerna run db:seed",
    "db:test": "lerna run db:generate && lerna run db:migrate:test"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "husky": "^9.1.7",
    "lerna": "^8.2.1",
    "lint-staged": "^15.5.0"
  },
  "workspaces": [
    "packages/api",
    "apps/*"
  ],
  "packageManager": "yarn@4.7.0"
}
