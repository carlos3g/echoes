generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "debian-openssl-1.1.x", "linux-arm64-openssl-1.1.x"]
}

datasource db {
  provider     = "postgresql"
  url          = env("DB_URL")
  relationMode = "foreignKeys"
}

generator dbml {
  provider = "prisma-dbml-generator"
}

model User {
  id                      BigInt                   @id @default(autoincrement()) @db.BigInt
  uuid                    String                   @unique
  name                    String
  email                   String                   @unique
  username                String                   @unique
  password                String
  emailVerifiedAt         DateTime?                @map("email_verified_at")
  passwordChangeRequests  PasswordChangeRequest[]
  emailConfirmationTokens EmailConfirmationToken[]
  tags                    Tag[]
  favoriteQuotes          UserFavoriteQuote[]
  favoriteAuthors         UserFavoriteAuthor[]
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @updatedAt @map("updated_at")
  avatarId                BigInt?                  @unique @map("avatar_id") @db.BigInt
  avatar                  File?                    @relation("UsersAvatars", fields: [avatarId], references: [id], onDelete: Cascade)

  @@map("users")
}

model PasswordChangeRequest {
  token     String    @id
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    BigInt    @db.BigInt
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("password_change_request")
}

model EmailConfirmationToken {
  token     String    @id
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    BigInt    @db.BigInt
  usedAt    DateTime? @map("used_at")
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("email_confirmation_token")
}

model Quote {
  id          BigInt              @id @default(autoincrement()) @db.BigInt
  uuid        String              @unique
  body        String
  author      Author?             @relation(fields: [authorId], references: [id])
  authorId    BigInt?             @db.BigInt
  sources     Source[]
  categories  Category[]
  favoritedBy UserFavoriteQuote[]
  tags        TagQuote[]
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  @@map("quotes")
}

model UserFavoriteQuote {
  id        BigInt   @id @default(autoincrement()) @db.BigInt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    BigInt   @db.BigInt
  quote     Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  quoteId   BigInt   @db.BigInt
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, quoteId])
  @@map("user_favorite_quotes")
}

model UserFavoriteAuthor {
  id        BigInt   @id @default(autoincrement()) @db.BigInt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    BigInt   @db.BigInt
  author    Author   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId  BigInt   @db.BigInt
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, authorId])
  @@map("user_favorite_authors")
}

model TagQuote {
  id        BigInt   @id @default(autoincrement()) @db.BigInt
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId     BigInt   @db.BigInt
  quote     Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  quoteId   BigInt   @db.BigInt
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([tagId, quoteId])
  @@map("tag_quotes")
}

model TagAuthor {
  id        BigInt   @id @default(autoincrement()) @db.BigInt
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId     BigInt   @db.BigInt
  author    Author   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId  BigInt   @db.BigInt
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([tagId, authorId])
  @@map("tag_authors")
}

model Source {
  id        BigInt   @id @default(autoincrement()) @db.BigInt
  uuid      String   @unique
  title     String
  quote     Quote    @relation(fields: [quoteId], references: [id])
  quoteId   BigInt   @db.BigInt
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("sources")
}

model Category {
  id        BigInt   @id @default(autoincrement()) @db.BigInt
  uuid      String   @unique
  title     String
  quotes    Quote[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("categories")
}

model Author {
  id          BigInt               @id @default(autoincrement()) @db.BigInt
  uuid        String               @unique
  name        String
  birthDate   DateTime             @map("birth_date")
  deathDate   DateTime?            @map("death_date")
  bio         String
  quotes      Quote[]
  tags        TagAuthor[]
  favoritedBy UserFavoriteAuthor[]
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")

  @@map("authors")
}

model Tag {
  id        BigInt      @id @default(autoincrement()) @db.BigInt
  uuid      String      @unique
  title     String
  user      User        @relation(fields: [userId], references: [id])
  userId    BigInt      @db.BigInt
  tags      TagQuote[]
  authors   TagAuthor[]
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  @@map("tags")
}

model File {
  id     BigInt @id @default(autoincrement()) @db.BigInt
  bucket String
  key    String
  users  User[] @relation("UsersAvatars")

  @@unique([bucket, key])
  @@map("files")
}
