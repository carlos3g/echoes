{
  "name": "@echoes/api",
  "version": "0.0.1",
  "description": "",
  "license": "MIT",
  "author": "carlos3g",
  "scripts": {
    "build": "nest build",
    "check": "tsc --noEmit",
    "db:fresh": "yarn db:generate && yarn db:migrate && yarn db:seed",
    "db:generate": "prisma generate",
    "db:migrate": "prisma db push",
    "db:migrate:test": "dotenv -e .env.testing -- prisma db push --accept-data-loss",
    "db:seed": "prisma db seed",
    "dev": "yarn start:dev",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "start": "nest start",
    "start:debug": "nest start --debug --watch",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "start:repl": "nest start --watch --entryFile repl",
    "style": "yarn format && yarn lint && yarn check",
    "test": "jest",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --runInBand --config ./test/jest-e2e.json",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.758.0",
    "@nestjs-modules/mailer": "^2.0.2",
    "@nestjs/common": "^11.0.11",
    "@nestjs/config": "^4.0.1",
    "@nestjs/core": "^11.0.11",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/platform-express": "^11.0.11",
    "@nestjs/schedule": "^5.0.1",
    "@nestjs/swagger": "^11.0.6",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.4.0",
    "@prisma/client": "^6.5.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "helmet": "^8.0.0",
    "image-size": "^2.0.1",
    "jdenticon": "^3.3.0",
    "lodash": "^4.17.21",
    "luxon": "^3.5.0",
    "mjml": "^4.15.3",
    "nestjs-cls": "^5.4.0",
    "nodemailer": "^6.10.0",
    "prisma": "^6.5.0",
    "pug": "^3.0.3",
    "qs": "^6.14.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.33.5",
    "type-fest": "^4.37.0",
    "uuid": "^11.1.0",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.6.0",
    "@nestjs/cli": "^11.0.5",
    "@nestjs/schematics": "^11.0.2",
    "@nestjs/testing": "^11.0.11",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/lodash": "^4.17.16",
    "@types/luxon": "^3.4.2",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.10",
    "@types/nodemailer": "^6.4.17",
    "@types/qs": "^6",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@types/zxcvbn": "^4.4.5",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "aws-sdk-client-mock": "^4.1.0",
    "aws-sdk-client-mock-jest": "^4.1.0",
    "dotenv": "^16.4.7",
    "dotenv-cli": "^8.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jest": "^28.11.0",
    "eslint-plugin-n": "^16",
    "eslint-plugin-prettier": "^5.2.3",
    "eslint-plugin-promise": "^6",
    "jest": "^29.7.0",
    "jest-mock": "^29.7.0",
    "prettier": "^3.5.3",
    "prettier-plugin-packagejson": "^2.5.10",
    "prisma-dbml-generator": "^0.12.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.6",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.2",
    "webpack": "^5.98.0"
  },
  "overrides": {
    "@nestjs-modules/mailer": {
      "@nestjs/common": "$@nestjs/common"
    }
  },
  "prisma": {
    "seed": "ts-node --transpile-only -P ./tsconfig.json prisma/seed.ts"
  }
}
